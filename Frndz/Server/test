import express from 'express';
import mongoose from 'mongoose';
import cors from 'cors';
import { Server } from 'socket.io';
import http from 'http';
import path from 'path';
import { fileURLToPath } from 'url';

// Import your Models for the test route
import User from './models/Users.js';
import Post from './models/Posts.js';

import authRoutes from './routes/Route.js';
import SocketHandler from './SocketHandler.js';

// Config for ES Modules
const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const app = express();

// Middleware
app.use(cors()); // Fixed: removed the double app.use
app.use(express.json({ limit: "30mb" })); // Use built-in express instead of body-parser
app.use(express.urlencoded({ limit: "30mb", extended: true }));

// Routes
app.use('/auth', authRoutes);

// --- INTEGRATED TEST ROUTE ---
app.post('/test-setup', async (req, res) => {
    try {
        const newUser = await User.create({
            username: "SocialMaster",
            email: "admin@socialex.com",
            password: "password123",
            about: "Admin of socialeX"
        });

        const newPost = await Post.create({
            userId: newUser._id,
            userName: newUser.username,
            file: "https://example.com",
            description: "Database initialized successfully!",
        });

        res.status(201).json({ message: "socialeX DB Created!", user: newUser, post: newPost });
    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});

// Socket.io Setup
const server = http.createServer(app);
const io = new Server(server, {
    cors: {
        origin: '*',
        methods: ['GET', 'POST', 'PUT', 'DELETE']
    }
});

io.on("connection", (socket) => {
    console.log("User connected via Socket");
    SocketHandler(socket);
});

// Database & Server Setup
const PORT = 6001;
const MONGO_URI = 'mongodb://localhost:27017/socialeX';

mongoose.connect(MONGO_URI)
    .then(() => {
        console.log("✅ MongoDB Connected: socialeX");
        server.listen(PORT, () => {
            console.log(`🚀 Server Running @ http://localhost:${PORT}`);
        });
    })
    .catch((e) => console.log(`❌ Connection Error: ${e}`));
